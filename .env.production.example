# ============================================================
# PicSelect — Production Environment Variables
# Copy to .env.local for local dev, set in Vercel dashboard for production
# ============================================================

# --- Database (Postgres) ---
# Use a connection pooling URL (e.g. Supabase pooler, PgBouncer) for serverless
DATABASE_URL="postgresql://user:password@host:5432/picselect?pgbouncer=true&connection_limit=1"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"
# Must match your deployed domain exactly (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"

# --- Google OAuth ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# --- Google Drive (optional — for public folder fallback via API key) ---
# Not required if photographers always sign in with Google OAuth
# Create at https://console.cloud.google.com/apis/credentials (API key, restrict to Drive API)
GOOGLE_API_KEY=""

# --- App URL (used in share links) ---
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
